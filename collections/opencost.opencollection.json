              },
              {
                "name": "aggregate",
                "value": "",
                "type": "query"
              },
              {
                "name": "accumulate",
                "value": "",
                "type": "query"
              },
              {
                "name": "filter",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieves non-Kubernetes cloud provider costs via cloud integration."
        }
      ]
    },
    {
      "info": {
        "name": "CustomCost",
